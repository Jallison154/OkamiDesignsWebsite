# Okami Designs — server configuration
# Copy to .env and set values before production deploy.
# Never commit .env or put secrets in frontend code.

PORT=3000
NODE_ENV=development

# Comma-separated origins allowed in production (empty = no wildcard CORS in production)
# Example: https://okamidesigns.com,https://www.okamidesigns.com
OKAMI_CORS_ALLOWED_ORIGINS=

# Public analytics view recording rate limit
OKAMI_ANALYTICS_RATE_WINDOW_MS=60000
OKAMI_ANALYTICS_RATE_MAX=60

# Master switch for commercial API behavior (entitlements, license verify)
OKAMI_COMMERCIAL_ENABLED=false

# Show license panel / upgrade UI in tools (requires commercial API; still safe when commercial is off)
OKAMI_CLIENT_COMMERCIAL_UI=false

# Staging-only dev license key — server-side only, never expose to browsers
OKAMI_LICENSE_DEV_ACCEPT_KEY=

# Tier granted by dev accept key: free | standard | professional
OKAMI_LICENSE_DEV_ACCEPT_TIER=standard

# Staging magic-link stub (no email sent)
OKAMI_ACCOUNT_MAGIC_LINK_STUB=false

# License verify HTTP path appended to OKAMI_LICENSE_SERVER_URL
OKAMI_LICENSE_VERIFY_PATH=/verify
OKAMI_LICENSE_VERIFY_TIMEOUT_MS=10000

# When true, startup fails if commercial env is incomplete
OKAMI_COMMERCIAL_STRICT=false

# External license server (desktop + web activation)
OKAMI_LICENSE_SERVER_URL=
OKAMI_LICENSE_API_KEY=

# Optional account / identity provider for user sessions
OKAMI_ACCOUNT_SERVICE_URL=

# Signed update feed for desktop app version checks
OKAMI_UPDATE_FEED_URL=
OKAMI_UPDATE_FEED_TIMEOUT_MS=10000

# Session signing secret for account cookies (generate a long random string)
OKAMI_SESSION_SECRET=
